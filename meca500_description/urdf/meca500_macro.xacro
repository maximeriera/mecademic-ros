        <origin xyz="0 0 -0.006" rpy="0 0 0"/>
        <geometry>
          <box size="0.06 0.065 0.07"/>
        </geometry>
      </collision>
    </link>

    <joint name="meca_axis_4" type="revolute">
      <parent link="link_3"/>
      <child link="link_4"/>
      <origin xyz="0 0 0.038" rpy="0 1.5708 0"/> <axis xyz="0 0 1"/>
      <limit lower="-2.96" upper="2.96" effort="1.25" velocity="6.108"/>
    </joint>

    <link name="link_4">
      <visual>
        <origin xyz="0 0 0.120" rpy="0 0 3.14159265"/>
        <geometry>
          <mesh filename="package://meca500_description/meshes/link_4.dae"/>
        </geometry>
        <material name="grey"/>
      </visual>
      <inertial>
        <origin xyz="0.00006098710044 0.00224976832 0.08976460875" rpy="0 0 3.1415"/>
        <mass value="0.2093565436"/>
        <inertia ixx="0.0002307486811" ixy="-2.55E-07" ixz="-1.76E-07" iyy="0.0001528092348" iyz="-0.00001834894489" izz="0.0001573266858"/>
      </inertial>
      <collision>
        <origin xyz="0 0 0.1025" rpy="0 0 0"/>
        <geometry>
          <box size="0.045 0.075 0.08"/>
        </geometry>
      </collision>
    </link>

    <joint name="meca_axis_5" type="revolute">
      <parent link="link_4"/>
      <child link="link_5"/>
      <origin xyz="0 0 0.120" rpy="0 0 0"/> <axis xyz="0 1 0"/>
      <limit lower="-2.00" upper="2.00" effort="1.25" velocity="6.108"/>
    </joint>

    <link name="link_5">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://meca500_description/meshes/link_5.dae"/>
        </geometry>
        <material name="grey"/>
      </visual>
      <inertial>
        <origin xyz="0.0000355330703 0.003727390331 0.02216669127" rpy="1.57 0 3.1415"/>
        <mass value="0.4881954861"/>
        <inertia ixx="0.0004368686961" ixy="8.60E-07" ixz="-3.41E-07" iyy="0.0001588423228" iyz="0.00002942257626" izz="0.0004066877932"/>
      </inertial>
      <collision>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <geometry>
          <box size="0.045 0.047 0.08"/>
        </geometry>
      </collision>
    </link>

    <joint name="meca_axis_6" type="revolute">
      <parent link="link_5"/>
      <child link="link_6"/>
      <origin xyz="0 0 0.070" rpy="0 0 0"/> <axis xyz="0 0 1"/>
      <limit lower="-6.28" upper="6.28" effort="0.75" velocity="8.726"/>
    </joint>

    <link name="link_6">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://meca500_description/meshes/link_6.dae"/>
        </geometry>
        <material name="grey"/>
      </visual>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0"/>
        <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
      </inertial>
      <collision>
        <origin xyz="0 0 -0.01" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.015" length="0.02"/>
        </geometry>
      </collision>
    </link>

  </xacro:macro>
</robot>