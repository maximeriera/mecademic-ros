<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="meca500" params="parent *origin">

    <material name="grey">
      <color rgba="0.2 0.2 0.2 1.0"/>
    </material>

    <joint name="${parent}_to_base_link" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}"/>
      <child link="base_link"/>
    </joint>

    <link name="base_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://meca500_description/meshes/link_0.dae"/>
        </geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.045" length="0.105"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="-0.0125 0 0.03" rpy="0 0 0"/>
        <geometry>
          <box size="0.115 0.090 0.06"/>
        </geometry>
      </collision>
    </link>

    <joint name="meca_axis_1" type="revolute">
      <parent link="base_link"/>
      <child link="link_1"/>
      <origin xyz="0 0 0.135" rpy="0 0 0"/> <axis xyz="0 0 1"/>
      <limit lower="-3.05" upper="3.05" effort="8.4" velocity="3.926"/>
    </joint>

    <link name="link_1">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://meca500_description/meshes/link_1.dae"/>
        </geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 -0.005" rpy="0 0 0"/>
        <geometry>
          <box size="0.065 0.1 0.08"/>
        </geometry>
      </collision>
    </link>

    <joint name="meca_axis_2" type="revolute">
      <parent link="link_1"/>
      <child link="link_2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/> <axis xyz="0 1 0"/>
      <limit lower="-1.22" upper="1.57" effort="8.4" velocity="3.926"/>
    </joint>

    <link name="link_2">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://meca500_description/meshes/link_2.dae"/>
        </geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="-0.005 0 0.025" rpy="0 -0.23 0"/>
        <geometry>
          <box size="0.067 0.065 0.11"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="-0.007 0 0.10" rpy="0 0.18 0"/>
        <geometry>
          <box size="0.06 0.1 0.13"/>
        </geometry>
      </collision>
    </link>

    <joint name="meca_axis_3" type="revolute">
      <parent link="link_2"/>
      <child link="link_3"/>
      <origin xyz="0 0 0.135" rpy="0 0 0"/> <axis xyz="0 1 0"/>
      <limit lower="-2.35" upper="1.22" effort="8.4" velocity="3.926"/>
    </joint>

    <link name="link_3">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://meca500_description/meshes/link_3.dae"/>
        </geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="0.017 0 0.03" rpy="0 0 0"/>
        <geometry>
          <box size="0.09 0.045 0.065"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 -0.006" rpy="0 0 0"/>
        <geometry>
          <box size="0.06 0.065 0.07"/>
        </geometry>
      </collision>
    </link>

    <joint name="meca_axis_4" type="revolute">
      <parent link="link_3"/>
      <child link="link_4"/>
      <origin xyz="0 0 0.038" rpy="0 1.5708 0"/> <axis xyz="0 0 1"/>
      <limit lower="-2.96" upper="2.96" effort="1.25" velocity="6.108"/>
    </joint>

    <link name="link_4">
      <visual>
        <origin xyz="0 0 0.120" rpy="0 0 3.14159265"/>
        <geometry>
          <mesh filename="package://meca500_description/meshes/link_4.dae"/>
        </geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.1025" rpy="0 0 0"/>
        <geometry>
          <box size="0.045 0.075 0.08"/>
        </geometry>
      </collision>
    </link>

    <joint name="meca_axis_5" type="revolute">
      <parent link="link_4"/>
      <child link="link_5"/>
      <origin xyz="0 0 0.120" rpy="0 0 0"/> <axis xyz="0 1 0"/>
      <limit lower="-2.00" upper="2.00" effort="1.25" velocity="6.108"/>
    </joint>

    <link name="link_5">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://meca500_description/meshes/link_5.dae"/>
        </geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <geometry>
          <box size="0.045 0.047 0.08"/>
        </geometry>
      </collision>
    </link>

    <joint name="meca_axis_6" type="revolute">
      <parent link="link_5"/>
      <child link="link_6"/>
      <origin xyz="0 0 0.070" rpy="0 0 0"/> <axis xyz="0 0 1"/>
      <limit lower="-6.28" upper="6.28" effort="0.75" velocity="8.726"/>
    </joint>

    <link name="link_6">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://meca500_description/meshes/link_6.dae"/>
        </geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 -0.01" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.015" length="0.02"/>
        </geometry>
      </collision>
    </link>

  </xacro:macro>
</robot>