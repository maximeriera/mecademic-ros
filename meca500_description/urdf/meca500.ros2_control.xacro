<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="meca500_ros2_control" params="name robot_ip">

    <ros2_control name="${name}" type="system">
      <hardware>
        <plugin>meca500_hardware/Meca500SystemHardware</plugin>
        <param name="robot_ip">${robot_ip}</param>
      </hardware>

      <joint name="meca_axis_1">
        <command_interface name="velocity">
          <param name="min">-2.61</param>
          <param name="max">2.61</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="meca_axis_2">
        <command_interface name="velocity">
          <param name="min">-2.61</param>
          <param name="max">2.61</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="meca_axis_3">
        <command_interface name="velocity">
          <param name="min">-3.14</param>
          <param name="max">3.14</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="meca_axis_4">
        <command_interface name="velocity">
          <param name="min">-5.23</param>
          <param name="max">5.23</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="meca_axis_5">
        <command_interface name="velocity">
          <param name="min">-5.23</param>
          <param name="max">5.23</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="meca_axis_6">
        <command_interface name="velocity">
          <param name="min">-8.72</param>
          <param name="max">8.72</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

    </ros2_control>
  </xacro:macro>
</robot>