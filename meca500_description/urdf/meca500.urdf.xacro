<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="Meca500_R4">

  <xacro:include filename="meca500_macro.xacro"/>
  <xacro:include filename="meca500.ros2_control.xacro"/>

  <link name="world"/>

  <xacro:meca500 parent="world">
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:meca500>

  <xacro:meca500_ros2_control name="Meca500System" robot_ip="192.168.0.100"/>

</robot>